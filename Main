<script>
// ── HERO CANVAS: animated data grid ──
(function() {
  const canvas = document.getElementById('heroCanvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, dots = [], animId;

  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    dots = [];
    const cols = Math.floor(W / 40), rows = Math.floor(H / 40);
    for (let i = 0; i <= cols; i++) {
      for (let j = 0; j <= rows; j++) {
        dots.push({
          x: i * 40, y: j * 40,
          baseX: i * 40, baseY: j * 40,
          phase: Math.random() * Math.PI * 2,
          speed: 0.3 + Math.random() * 0.4,
          r: 1.2 + Math.random() * 1.5,
          alpha: 0.1 + Math.random() * 0.25
        });
      }
    }
  }

  let t = 0;
  function draw() {
    ctx.clearRect(0, 0, W, H);
    t += 0.008;
    dots.forEach(d => {
      d.x = d.baseX + Math.sin(t * d.speed + d.phase) * 6;
      d.y = d.baseY + Math.cos(t * d.speed * 0.7 + d.phase) * 4;
      const a = d.alpha + Math.sin(t * d.speed + d.phase) * 0.15;
      ctx.beginPath();
      ctx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(0,212,180,${Math.max(0.05, a)})`;
      ctx.fill();
    });
    // subtle connecting lines
    for (let i = 0; i < dots.length; i += 12) {
      for (let j = i + 1; j < Math.min(i + 15, dots.length); j++) {
        const dx = dots[i].x - dots[j].x, dy = dots[i].y - dots[j].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < 55) {
          ctx.beginPath();
          ctx.moveTo(dots[i].x, dots[i].y);
          ctx.lineTo(dots[j].x, dots[j].y);
          ctx.strokeStyle = `rgba(0,212,180,${0.06 * (1 - dist/55)})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }
    animId = requestAnimationFrame(draw);
  }
  resize();
  window.addEventListener('resize', resize);
  draw();
})();

// ── ABOUT CANVAS: radial chart ──
(function() {
  const canvas = document.getElementById('aboutCanvas');
  if (!canvas) return;
  canvas.width = canvas.offsetWidth || 400;
  canvas.height = canvas.offsetHeight || 360;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2, R = Math.min(W,H)*0.38;
  const categories = ['AI & ML','Healthcare','Supply Chain','Finance','Policy','Sustainability'];
  const values = [0.88, 0.72, 0.94, 0.65, 0.58, 0.81];
  let anim = 0;
  function drawRadar(progress) {
    ctx.clearRect(0,0,W,H);
    const n = categories.length;
    const angle = (i) => (Math.PI * 2 / n) * i - Math.PI / 2;
    // grid rings
    [0.25,0.5,0.75,1].forEach(scale => {
      ctx.beginPath();
      for (let i = 0; i < n; i++) {
        const a = angle(i), px = cx + Math.cos(a)*R*scale, py = cy + Math.sin(a)*R*scale;
        i === 0 ? ctx.moveTo(px,py) : ctx.lineTo(px,py);
      }
      ctx.closePath();
      ctx.strokeStyle = 'rgba(0,212,180,0.12)'; ctx.lineWidth = 1; ctx.stroke();
    });
    // axes
    for (let i = 0; i < n; i++) {
      const a = angle(i);
      ctx.beginPath(); ctx.moveTo(cx,cy);
      ctx.lineTo(cx+Math.cos(a)*R, cy+Math.sin(a)*R);
      ctx.strokeStyle='rgba(0,212,180,0.15)'; ctx.lineWidth=1; ctx.stroke();
    }
    // data fill
    ctx.beginPath();
    for (let i = 0; i < n; i++) {
      const a = angle(i), v = values[i]*progress;
      const px = cx + Math.cos(a)*R*v, py = cy + Math.sin(a)*R*v;
      i === 0 ? ctx.moveTo(px,py) : ctx.lineTo(px,py);
    }
    ctx.closePath();
    ctx.fillStyle='rgba(0,212,180,0.12)'; ctx.fill();
    ctx.strokeStyle='rgba(0,212,180,0.7)'; ctx.lineWidth=2; ctx.stroke();
    // dots + labels
    for (let i = 0; i < n; i++) {
      const a = angle(i), v = values[i]*progress;
      const px = cx+Math.cos(a)*R*v, py = cy+Math.sin(a)*R*v;
      ctx.beginPath(); ctx.arc(px,py,4,0,Math.PI*2);
      ctx.fillStyle='#00D4B4'; ctx.fill();
      const lx = cx+Math.cos(a)*(R+28), ly = cy+Math.sin(a)*(R+28);
      ctx.fillStyle='rgba(248,249,250,0.7)';
      ctx.font='11px Inter, sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(categories[i], lx, ly);
    }
  }
  let start = null;
  function animFrame(ts) {
    if (!start) start = ts;
    anim = Math.min((ts - start) / 1200, 1);
    drawRadar(anim);
    if (anim < 1) requestAnimationFrame(animFrame);
  }
  const obs = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) { start = null; requestAnimationFrame(animFrame); obs.disconnect(); }
  }, {threshold: 0.3});
  obs.observe(canvas);
})();

// ── COUNTER ANIMATION ──
function animateCounter(el, target, suffix='') {
  let start = null, duration = 1800;
  function step(ts) {
    if (!start) start = ts;
    const p = Math.min((ts - start) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.floor(ease * target) + suffix;
    if (p < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}
const counters = [
  {id:'cnt1', val:4200, suffix:'+'},
  {id:'cnt2', val:12, suffix:''},
  {id:'cnt3', val:68, suffix:''},
  {id:'cnt4', val:3400, suffix:'+'},
];
const heroObs = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) {
    counters.forEach(c => {
      const el = document.getElementById(c.id);
      if (el) animateCounter(el, c.val, c.suffix);
    });
    heroObs.disconnect();
  }
}, {threshold: 0.3});
const heroStats = document.querySelector('.hero-stats');
if (heroStats) heroObs.observe(heroStats);

// ── FORM HANDLERS ──
function handleRegister() {
  const first = document.getElementById('firstName').value.trim();
  const email = document.getElementById('email').value.trim();
  const terms = document.getElementById('terms').checked;
  const memberType = document.getElementById('memberType').value;
  if (!first || !email || !memberType) { alert('Please fill in all required fields.'); return; }
  if (!terms) { alert('Please agree to the terms to continue.'); return; }
  document.getElementById('regForm').style.display = 'none';
  document.getElementById('successMsg').style.display = 'block';
}

function handleNewsletter() {
  const email = document.getElementById('nlEmail').value.trim();
  if (!email || !email.includes('@')) { alert('Please enter a valid email address.'); return; }
  document.getElementById('nlForm').style.display = 'none';
  document.getElementById('nlSuccess').style.display = 'block';
}

// ── SMOOTH NAV HIGHLIGHT ──
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-links a');
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(s => { if (window.scrollY >= s.offsetTop - 100) current = s.id; });
  navLinks.forEach(a => {
    a.style.color = a.getAttribute('href') === '#'+current ? '#fff' : '';
  });
}, {passive:true});
</script>
</body>
</html>
